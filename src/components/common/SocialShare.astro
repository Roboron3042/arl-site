---
import { Icon } from 'astro-icon/components';
import type { MetaDataMastodon } from '~/types';

export interface Props {
  text: string;
  url: string | URL;
  class?: string;
  mastodon?: MetaDataMastodon;
}

const { text, url, mastodon } = Astro.props;

const mastodonUrl = mastodon?.statusId
  ? `${mastodon?.instanceUrl ?? 'https://masto.es'}/statuses/${mastodon.statusId}`
  : `https://share.joinmastodon.org/#text=${text} ${url}`;
---

<div class="flex items-center">
  <span class="align-super font-bold text-slate-500 dark:text-slate-400">Compartir:</span>
  <a href={mastodonUrl} target="_blank" rel="noopener" class="ml-2 rtl:ml-0 rtl:mr-2">
    <Icon
      name="tabler:brand-mastodon"
      class="w-6 h-6 text-gray-400 dark:text-slate-500 hover:text-black dark:hover:text-slate-300"
    />
  </a>
  <button
    class="ml-2 rtl:ml-0 rtl:mr-2"
    title="Compartir por correo electrónico"
    data-aw-social-share="mail"
    data-aw-url={url}
    data-aw-text={text}
    ><Icon
      name="tabler:mail"
      class="w-6 h-6 text-gray-400 dark:text-slate-500 hover:text-black dark:hover:text-slate-300"
    />
  </button>
</div>
